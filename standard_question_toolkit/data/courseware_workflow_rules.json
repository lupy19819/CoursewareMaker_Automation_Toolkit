{
  "version": "2026-04-24",
  "purpose": "CoursewareMaker 自动化生成流程与生成后校验基准。生成配置后，validate_config.js 读取 validation_baselines 中的 expected_config 做结构、皮肤、组件资源和布局校验。",
  "platform_creation_profiles": {
    "_note": "仅用于平台创建接口参数，不作为玩法路由标准。玩法路由必须以 route_first[].baseline_json_path 和 data_shape 为准。",
    "componentized": "70a3010b-0b7a-11ef-b3a3-fa7902489df6",
    "yundong_pk": "47995925-fb37-11ef-8c1b-ce918f8037e8"
  },
  "workflow": {
    "route_first": [
      {
        "when": "游戏名称或类型包含 赛跑、游泳、赛车、运动PK",
        "gameplay_family": "yundong_pk",
        "data_shape": "custom_game",
        "baseline_json_path": "templates/detail_jsons/run_detail.json",
        "skin_baseline_paths": {
          "run": "templates/detail_jsons/run_detail.json",
          "swim": "templates/detail_jsons/swim_detail.json",
          "racecar": "templates/detail_jsons/racecar_detail.json"
        },
        "build_script": "scripts/build_yundong_pk_config.py"
      },
      {
        "when": "其他组件化游戏：标准题型、贪吃小怪兽、画板类等",
        "gameplay_family": "componentized",
        "data_shape": "game",
        "baseline_json_path": "standard_question_toolkit/templates/base_choice_fill_template.json",
        "build_scripts": [
          "standard_question_toolkit/scripts/generate_grade3_config.py",
          "standard_question_toolkit/scripts/generate_grade4_config.py",
          "scripts/build_sj6_monster_config.py"
        ]
      }
    ],
    "stages": [
      "准备题目结构和素材清单",
      "上传素材资源并确认 URL",
      "按玩法路由生成配置 JSON",
      "按本文件 validation_baselines 校验生成配置",
      "按玩法路由的数据结构选择创建/保存路径：custom_game 走运动PK结构，game 走组件化结构",
      "生成分享链接或发布游戏"
    ],
    "post_generation_gate": {
      "command": "node scripts/validate_config.js --file <config.json>",
      "must_pass_before_save": true
    }
  },
  "component_ids": {
    "choice": "3b9b8ec3-f7d3-11ee-b9ef-8e2f78cd4bcd",
