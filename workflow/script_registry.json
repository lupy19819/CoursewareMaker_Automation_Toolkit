{
  "version": "2026-05-14",
  "scripts": {
    "environment_check": "docs/check_environment.sh",
    "resource_sync": "scripts/sync_courseware_resources.py",
    "fetch_yach_sheet": "scripts/fetch_yach_sheet.py",
    "resolve_sheet_resources": "scripts/resolve_sheet_resources.py",
    "asset_upload": "scripts/courseware_bulk_upload_assets.mjs",
    "create_game": "scripts/create_game_auto.js",
    "save_via_cdp": "scripts/save_game_config_via_cdp.js",
    "roundtrip_compare": "scripts/roundtrip_compare_config.js",
    "create_preview_url": "scripts/create_preview_url.js",
    "run_courseware_task": "workflow/run_courseware_task.py",
    "save_via_api": "scripts/upload_game_config.py",
    "share_link": "scripts/generate_share_link.js",
    "publish_game": "scripts/publish_game_auto.js",
    "monitor_activity": "scripts/monitors/monitor_chrome_activity.js",
    "validate_generic": "scripts/validate_config.js",
    "validate_yundong_pk": "scripts/validate_yundong_pk_config.py",
    "validate_monster": "scripts/validate_monster_config.py",
    "validate_resources": "scripts/validate_resources.py"
  },
  "generation": {
    "yundong_pk": {
      "default": "scripts/build_yundong_pk_config.py"
    },
    "template_game": {
      "monster": "scripts/build_sj6_monster_config.py --xlsx <题目.xlsx> --sheet <SheetName> --resources <resources.json> --template reference_configs/monster/贪吃_reference_clean.json --output <输出.config.json> --meta <输出.build-meta.json>",
      "fanboat": "scripts/build_reading_config.py --type fanboat --options <3|4> --input <题目.json> --output <输出.config.json>",
      "train": "scripts/build_reading_config.py --type train --options <3|4> --input <题目.json> --output <输出.config.json>",
      "road_adventure": "scripts/generate_guoji_l2_shu4_road.py --input <题目.json> --template <公路参考配置.json> --output <输出.config.json> --meta <输出.build-meta.json>",
      "spelling": "scripts/generate_spelling_config.py --input <题目.json> --output <输出.config.json> --meta <输出.build-meta.json>",
      "magic_spelling": "scripts/generate_mofappl_config.py --input <题目.json> --output <输出.config.json> --meta <输出.build-meta.json>",
      "bridge": "scripts/generate_guoqiao_shu2.py --input <题目.json> --template <过桥参考配置.json> --output <输出.config.json> --meta <输出.build-meta.json>",
      "amusement_park": "scripts/generate_kaixin_shu2.py --input <题目.json> --template <开心游乐园参考配置.json> --output <输出.config.json> --meta <输出.build-meta.json>"
    },
    "standard_component": {
      "default": "standard_question_toolkit/scripts/generate_*.py"
    }
  },
  "monitors": {
    "manual_operation": "scripts/monitors/monitor_chrome_activity.js",
    "create_yundong_pk": "scripts/monitors/monitor_create_yundongpk.js",
    "publish": "scripts/monitors/monitor_game_publish.js",
    "share_link": "scripts/monitors/monitor_share_link.js"
  }
}
